ENVIRONMENT=development
PORT=4000

# Local MongoDB (change to "mongodb://mongo:27017/vacations" when running inside docker-compose).
MONGODB_CONNECTION_STRING=mongodb://127.0.0.1:27017/vacations

# JWT / hashing secrets. Must be long random strings in production.
JWT_SECRET=change-me-to-a-long-random-string
BCRYPT_ROUNDS=10

# Optional legacy salt used only to verify and upgrade older HMAC-based
# password hashes from pre-bcrypt builds.
HASH_SALT=

# AI provider (OpenAI). Leave blank to disable AI + MCP question endpoints.
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Optional. Public URL of this backend's /sse endpoint so OpenAI can reach the MCP server.
# When empty, /api/mcp/ask falls back to an in-process MCP client.
MCP_PUBLIC_URL=

# Seeding toggle (set to "true" to run the idempotent seeder on boot).
RUN_SEED=true

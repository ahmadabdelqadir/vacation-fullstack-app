# Docker Compose reads this file automatically when you run
# `docker compose up` from the project root. Copy it to `.env`
# and fill in the secrets. `.env` is gitignored.

# Backend env (propagated into the backend container by docker-compose.yml):
JWT_SECRET=change-me-to-a-long-random-string
HASH_SALT=
BCRYPT_ROUNDS=10

# OpenAI API key. Leave empty to run without AI features.
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Public URL of `/sse` for OpenAI-driven MCP mode.
# Leave empty to use the in-process MCP router fallback.
MCP_PUBLIC_URL=
